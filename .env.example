ERPNEXT_URL=YOUR_ERPNEXT_URL_HERE
ERPNEXT_SITE_NAME=YOUR_ERPNEXT_SITE_NAME_HERE
ERPNEXT_API_KEY=YOUR_ERPNEXT_API_KEY_HERE
ERPNEXT_API_SECRET=YOUR_ERPNEXT_API_SECRET_HERE
ERPNEXT_COMPANY_NAME=YOUR_COMPANY_NAME_HERE
ERPNEXT_PARENT_WAREHOUSE=YOUR_PARENT_WAREHOUSE_HERE
# Group warehouse for buyer (customer) stock — must exist in ERPNext under All Warehouses
ERPNEXT_BUYER_WAREHOUSE=YOUR_BUYER_WAREHOUSE_HERE
SESSION_SECRET=YOUR_SESSION_SECRET_HERE
OFFER_TOKEN_SECRET=YOUR_OFFER_TOKEN_SECRET_HERE
SUPPLIER_ALIAS_SALT=YOUR_SUPPLIER_ALIAS_SALT_HERE
DATABASE_URL=YOUR_DATABASE_URL_HERE
# Turso auth token (required for libsql:// URLs; omit for local file: URLs)
DATABASE_AUTH_TOKEN=your-turso-auth-token
RESEND_API_KEY=YOUR_RESEND_API_KEY_HERE
RESET_TOKEN_SECRET=YOUR_RESET_TOKEN_SECRET_HERE
NEXT_PUBLIC_APP_URL=YOUR_NEXT_PUBLIC_APP_URL_HERE
DEV_EMAIL_OVERRIDE=YOUR_DEV_EMAIL_OVERRIDE_HERE
ADMIN_NOTIFICATION_EMAIL=YOUR_ADMIN_EMAIL_HERE
CREDENTIAL_ENCRYPTION_SECRET=YOUR_CREDENTIAL_ENCRYPTION_SECRET_HERE
# Local: redis://127.0.0.1:6379 — Upstash prod: rediss://default:TOKEN@HOST.upstash.io:6379 (URL only, no --tls/-u flags)
REDIS_URL=redis://127.0.0.1:6379
ADMIN_API_KEY=YOUR_ADMIN_API_KEY_HERE
